<!-- Features Grid -->
<section class="py-24 bg-white/30 backdrop-blur-sm border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-slate-900 mb-4">Inovasi di v4.0.0</h2>
            <div class="w-20 h-1.5 bg-blue-600 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Feature 1: Modern Routing -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 mb-6 text-2xl">
                    🛤
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">Modern Routing DSL</h3>
                <p class="text-slate-600 leading-relaxed">DSL intuitif dengan dukungan parameter dinamis <code>:id</code>, namespace, dan kontrol eksekusi <code>halt</code>.</p>
            </div>

            <!-- Feature 2: URL Mapping -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 mb-6 text-2xl">
                    🗺
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">URL Mapping</h3>
                <p class="text-slate-600 leading-relaxed">Jalankan banyak aplikasi independen di bawah satu server dengan pemetaan jalur (path mapping) yang fleksibel.</p>
            </div>

            <!-- Feature 3: Security Pack -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center text-emerald-600 mb-6 text-2xl">
                    🔐
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">Security Suite</h3>
                <p class="text-slate-600 leading-relaxed">Session terenkripsi HMAC-SHA256, proteksi XSS otomatis, dan perlindungan DoS bawaan.</p>
            </div>

            <!-- Feature 4: Smart Templating -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-amber-600 mb-6 text-2xl">
                    🎨
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">Smart Templating</h3>
                <p class="text-slate-600 leading-relaxed">Sistem Auto-Layout (ERB), injeksi objek <code>@req/@res</code>, dan helper keamanan <code>@h</code> terintegrasi.</p>
            </div>

            <!-- Feature 5: Application Cascade -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-rose-100 rounded-xl flex items-center justify-center text-rose-600 mb-6 text-2xl">
                    🌊
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">App Cascading</h3>
                <p class="text-slate-600 leading-relaxed">Gunakan Cascade untuk mencoba beberapa aplikasi secara bergantian hingga permintaan berhasil ditangani.</p>
            </div>

            <!-- Feature 6: Production Ready -->
            <div class="glass-card p-8 rounded-3xl">
                <div class="w-12 h-12 bg-cyan-100 rounded-xl flex items-center justify-center text-cyan-600 mb-6 text-2xl">
                    ⚡
                </div>
                <h3 class="text-xl font-bold text-slate-900 mb-3">Eksa-Server Power</h3>
                <p class="text-slate-600 leading-relaxed">Terintegrasi penuh dengan engine server performa tinggi untuk lingkungan produksi skala besar.</p>
            </div>
        </div>
    </div>
</section>

<!-- Quick Start -->
<section class="py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="glass p-6 sm:p-12 rounded-[30px] sm:rounded-[40px] shadow-2xl">
            <h2 class="text-3xl font-extrabold text-slate-900 mb-8 text-center">Memulai Cepat Gaya v4</h2>
            <div class="space-y-6">
                <p class="text-slate-600 font-medium ml-2 text-center">Definisikan aplikasi Anda di <code class="bg-blue-50 text-blue-600 px-2 py-1 rounded">config.eks</code>:</p>
                <div class="relative group">
                    <pre><code class="language-ruby"># config.eks
use EksCent::Middleware::Logger

map "/api" do
  api = EksCent::Router.new do
    get '/status' do |req, res|
      res.write({ status: 'online', v: EksCent::VERSION }.to_json)
    end
  end
  run api
end

router = EksCent::Router.new do
  get '/' do |req, res|
    res.write "&lt;h1&gt;Eks-Cent v#{EksCent::VERSION} Aktif!&lt;/h1&gt;"
  end
end

run router</code></pre>
                </div>
                <p class="text-slate-600 font-medium mt-10 ml-2 text-center">Jalankan dengan mode auto-reload:</p>
                <div class="bg-slate-900 text-slate-200 p-8 rounded-2xl font-mono shadow-inner border border-slate-700 flex items-center justify-between">
                    <div>
                        <span class="text-emerald-400">$</span> ekscentup -R --port 3000
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
