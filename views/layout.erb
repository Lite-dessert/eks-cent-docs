<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @title || 'Eks-Cent' %></title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="canonical" href="<%= @base_url %><%= @path %>">
    
    <!-- SEO & OpenGraph Meta Tags -->
    <meta name="description" content="Eks-Cent: Framework web Ruby ringan, ultra-cepat, dan sangat aman terinspirasi oleh Rack.">
    <meta property="og:title" content="<%= @title || 'Eks-Cent Framework' %>">
    <meta property="og:description" content="Framework web Ruby modern yang mengutamakan performa tanpa dependensi berat.">
    <meta property="og:image" content="<%= @base_url %>/opengraph.png">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="<%= @base_url %>/opengraph.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at top right, #f8fafc, #eff6ff, #fcfcfc);
            min-height: 100vh;
        }
        .glass {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: all 0.3s ease;
        }
        .glass-card:hover {
            background: rgba(255, 255, 255, 0.8);
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.05);
        }
        .nav-link {
            transition: all 0.2s;
        }
        .nav-link:hover {
            color: #2563eb;
        }
        pre {
            background: rgba(30, 41, 59, 0.95);
            color: #e2e8f0;
            padding: 1.5rem;
            border-radius: 12px;
            overflow-x: auto;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        code {
            font-family: 'Fira Code', monospace;
        }
    </style>
</head>
<body class="text-slate-800">
    <!-- Navbar -->
    <nav class="sticky top-0 z-50 glass border-b border-white/20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold shadow-lg shadow-blue-200">
                        E
                    </div>
                    <span class="text-xl font-bold tracking-tight text-slate-900">Eks-Cent</span>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="nav-link text-slate-600 font-medium">Beranda</a>
                    <a href="/docs" class="nav-link text-slate-600 font-medium">Dokumentasi</a>
                    <a href="https://github.com/IshikawaUta/eks-cent" target="_blank" class="nav-link text-slate-600 font-medium">GitHub</a>
                </div>
                <div>
                   <a href="/docs" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-full font-medium transition-colors shadow-md shadow-blue-100">
                        Coba Sekarang
                   </a>
                </div>
            </div>
        </div>
    </nav>

    <main>
        <%= @content %>
    </main>

    <!-- Footer -->
    <footer class="mt-20 border-t border-slate-200/60 pb-12 pt-16">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-500">
            <p>© 2026 Eks-Cent Framework.</p>
        </div>
    </footer>
</body>
</html>
